calibration_table[i,j] <- cur_calibration/repeats
# print(paste0("b_intervention =", i, "cmi = ", j, "mse = ", mse_table[i,j]))
}
}
aucgrid_list[[p]] <- auc_table
msegrid_list[[p]] <- mse_table
calibrationgrid_list[[p]] <- calibration_table
}
